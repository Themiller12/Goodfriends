import React, { useState, useCallback, useRef } from 'react';
import {
  View,
  Text,
  StyleSheet,
  FlatList,
  RefreshControl,
  Alert,
  TouchableOpacity,
  Modal,
  TextInput,
  ActivityIndicator,
  ScrollView,
  Platform,
} from 'react-native';
import MaterialIcons from 'react-native-vector-icons/MaterialIcons';
import { useNavigation, useFocusEffect } from '@react-navigation/native';
import { NativeStackNavigationProp } from '@react-navigation/native-stack';
import { useTheme } from '../context/ThemeContext';
import { Neutral, Spacing, Radius, Shadow, Typography } from '../theme/designSystem';
import MessageService, { Conversation } from '../services/MessageService';
import StorageService from '../services/StorageService';
import FriendRequestService from '../services/FriendRequestService';
import OnlineStatusService from '../services/OnlineStatusService';
import GroupChatService from '../services/GroupChatService';
import OnlineIndicator from '../components/OnlineIndicator';
import { Contact, GroupChat, GroupMember } from '../types';

type NavigationProp = NativeStackNavigationProp<any>;

// Unified list item
type UnifiedItem =
  | { kind: 'dm'; conv: Conversation; lastTime: string }
  | { kind: 'group'; group: GroupChat; lastTime: string };

const ConversationsScreen: React.FC = () => {
  const { theme } = useTheme();
  const navigation = useNavigation<NavigationProp>();
  const S = styles(theme);

  const [conversations, setConversations] = useState<Conversation[]>([]);
  const [groupChats, setGroupChats] = useState<GroupChat[]>([]);
  const [unified, setUnified] = useState<UnifiedItem[]>([]);
  const [filtered, setFiltered] = useState<UnifiedItem[]>([]);
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const [totalUnread, setTotalUnread] = useState(0);
  const [onlineStatuses, setOnlineStatuses] = useState<Record<string, boolean>>({});

  // New conversation modal
  const [modalVisible, setModalVisible] = useState(false);
  const [goodFriendsContacts, setGoodFriendsContacts] = useState<Contact[]>([]);
  const [loadingContacts, setLoadingContacts] = useState(false);
  const [selectedIds, setSelectedIds] = useState<string[]>([]);
  const [groupStep, setGroupStep] = useState<'select' | 'name'>('select');
  const [groupName, setGroupName] = useState('');
  const [creatingGroup, setCreatingGroup] = useState(false);

  const pollingRef = useRef<ReturnType<typeof setInterval> | null>(null);

  useFocusEffect(
    useCallback(() => {
      loadAll();

      pollingRef.current = setInterval(async () => {
        loadAll(true);
        try {
          await MessageService.checkNewMessages();
          await FriendRequestService.checkNewFriendRequests();
        } catch {}
      }, 5000);

      return () => {
        if (pollingRef.current) clearInterval(pollingRef.current);
      };
    }, [])
  );

  const buildUnified = (convs: Conversation[], groups: GroupChat[]) => {
    const items: UnifiedItem[] = [
      ...convs.map(c => ({
        kind: 'dm' as const,
        conv: c,
        lastTime: c.lastMessageTime || '1970-01-01',
      })),
      ...groups.map(g => ({
        kind: 'group' as const,
        group: g,
        lastTime: g.updatedAt || '1970-01-01',
      })),
    ];
    items.sort((a, b) => new Date(b.lastTime).getTime() - new Date(a.lastTime).getTime());
    return items;
  };

  const loadAll = async (silent = false) => {
    try {
      if (!silent) setLoading(true);

      const [convs, groups] = await Promise.all([
        MessageService.getConversations(),
        GroupChatService.getAll(),
      ]);
      groups.sort((a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime());

      setConversations(convs);
      setGroupChats(groups);

      const merged = buildUnified(convs, groups);
      setUnified(merged);
      applyFilter(merged, searchQuery);

      const ids = convs.map(c => c.otherUserId);
      if (ids.length > 0) {
        OnlineStatusService.getStatuses(ids).then(setOnlineStatuses);
      }

      const unread = convs.reduce((sum, c) => sum + c.unreadCount, 0);
      setTotalUnread(unread);
    } catch (error) {
      if (!silent) Alert.alert('Erreur', 'Impossible de charger les conversations');
    } finally {
      if (!silent) setLoading(false);
      setRefreshing(false);
    }
  };

  const applyFilter = (items: UnifiedItem[], query: string) => {
    if (!query.trim()) {
      setFiltered(items);
      return;
    }
    const q = query.toLowerCase();
    setFiltered(items.filter(item => {
      if (item.kind === 'dm') {
        const c = item.conv;
        return (
          c.otherUserFirstName?.toLowerCase().includes(q) ||
          c.otherUserLastName?.toLowerCase().includes(q) ||
          c.otherUserEmail?.toLowerCase().includes(q) ||
          c.lastMessage?.toLowerCase().includes(q)
        );
      } else {
        const g = item.group;
        return (
          g.name.toLowerCase().includes(q) ||
          g.members.some(m =>
            m.firstName.toLowerCase().includes(q) || m.lastName.toLowerCase().includes(q)
          )
        );
      }
    }));
  };

  const handleSearchChange = (text: string) => {
    setSearchQuery(text);
    applyFilter(unified, text);
  };

  const handleRefresh = () => {
    setRefreshing(true);
    loadAll();
  };

  const openNewConversationModal = async () => {
    setSelectedIds([]);
    setGroupStep('select');
    setGroupName('');
    setModalVisible(true);
    setLoadingContacts(true);
    try {
      const contacts = await StorageService.getContacts();
      setGoodFriendsContacts(contacts.filter(c => !!c.goodfriendsUserId));
    } catch {
      Alert.alert('Erreur', 'Impossible de charger les contacts');
    } finally {
      setLoadingContacts(false);
    }
  };

  const toggleContact = (id: string) => {
    setSelectedIds(prev =>
      prev.includes(id) ? prev.filter(x => x !== id) : [...prev, id]
    );
  };

  const handleConfirmSelection = () => {
    if (selectedIds.length === 0) return;
    if (selectedIds.length === 1) {
      // Individual conversation
      const contact = goodFriendsContacts.find(c => c.id === selectedIds[0])!;
      setModalVisible(false);
      navigation.navigate('Chat', {
        otherUserId: contact.goodfriendsUserId,
        otherUserFirstName: contact.firstName,
        otherUserLastName: contact.lastName,
        otherUserEmail: contact.email,
      });
    } else {
      // Group: go to group name step
      setGroupStep('name');
    }
  };

  const handleCreateGroup = async () => {
    if (!groupName.trim()) {
      Alert.alert('Erreur', 'Veuillez entrer un nom pour le groupe');
      return;
    }
    setCreatingGroup(true);
    try {
      const members: GroupMember[] = selectedIds.map(cid => {
        const c = goodFriendsContacts.find(x => x.id === cid)!;
        return {
          userId: c.goodfriendsUserId ?? '',
          contactId: c.id,
          firstName: c.firstName,
          lastName: c.lastName,
          photo: c.photo,
        };
      });
      const newGroup = await GroupChatService.create(groupName.trim(), members);
      setModalVisible(false);
      loadAll(true);
      navigation.navigate('GroupChat', { groupId: newGroup.id });
    } catch {
      Alert.alert('Erreur', 'Impossible de créer le groupe');
    } finally {
      setCreatingGroup(false);
    }
  };

  const formatTime = (dateString: string) => {
    const date = new Date(dateString);
    const now = new Date();
    const diff = now.getTime() - date.getTime();
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    if (days === 0) return date.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    if (days === 1) return 'Hier';
    if (days < 7) return date.toLocaleDateString('fr-FR', { weekday: 'short' });
    return date.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit' });
  };

  const formatName = (firstName?: string | null, lastName?: string | null, email?: string) => {
    if (firstName && lastName) return `${firstName} ${lastName}`;
    if (firstName) return firstName;
    if (lastName) return lastName;
    return email || '';
  };

  const renderItem = ({ item }: { item: UnifiedItem }) => {
    if (item.kind === 'dm') {
      const c = item.conv;
      const name = formatName(c.otherUserFirstName, c.otherUserLastName, c.otherUserEmail);
      const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
      return (
        <TouchableOpacity
          style={[S.item, c.unreadCount > 0 && S.itemUnread]}
          onPress={() => navigation.navigate('Chat', {
            otherUserId: c.otherUserId,
            otherUserFirstName: c.otherUserFirstName,
            otherUserLastName: c.otherUserLastName,
            otherUserEmail: c.otherUserEmail,
          })}
          activeOpacity={0.7}>
          <View style={S.avatarCircle}>
            <Text style={S.avatarText}>{initials}</Text>
            <OnlineIndicator isOnline={onlineStatuses[c.otherUserId] ?? false} size={13} />
          </View>
          <View style={S.itemInfo}>
            <View style={S.itemTop}>
              <Text style={[S.itemName, c.unreadCount > 0 && S.itemNameBold]} numberOfLines={1}>{name}</Text>
              <Text style={S.timeText}>{formatTime(c.lastMessageTime)}</Text>
            </View>
            <View style={S.itemBottom}>
              <Text style={[S.lastMessage, c.unreadCount > 0 && S.lastMessageBold]} numberOfLines={1}>
                {c.lastMessage || '…'}
              </Text>
              {c.unreadCount > 0 && (
                <View style={S.badge}>
                  <Text style={S.badgeText}>{c.unreadCount > 99 ? '99+' : c.unreadCount}</Text>
                </View>
              )}
            </View>
          </View>
        </TouchableOpacity>
      );
    } else {
      const g = item.group;
      const { text, time } = GroupChatService.getLastMessage(g);
      const lastSender = g.messages.length > 0 ? g.messages[g.messages.length - 1].senderName : null;
      return (
        <TouchableOpacity
          style={S.item}
          onPress={() => navigation.navigate('GroupChat', { groupId: g.id })}
          activeOpacity={0.7}>
          <View style={[S.avatarCircle, { backgroundColor: theme.secondary || '#6d4c41' }]}>
            <MaterialIcons name="group" size={22} color="#FFF" />
          </View>
          <View style={S.itemInfo}>
            <View style={S.itemTop}>
              <Text style={S.itemName} numberOfLines={1}>{g.name}</Text>
              <Text style={S.timeText}>{formatTime(time)}</Text>
            </View>
            <Text style={S.lastMessage} numberOfLines={1}>
              {g.messages.length > 0
                ? `${lastSender}: ${text}`
                : `${g.members.length} membre${g.members.length > 1 ? 's' : ''}`}
            </Text>
          </View>
        </TouchableOpacity>
      );
    }
  };

  if (loading) {
    return (
      <View style={S.container}>
        <View style={S.header}>
          <Text style={S.headerTitle}>Messages</Text>
        </View>
        <View style={S.loadingContainer}>
          <ActivityIndicator size="large" color={theme.primary} />
        </View>
      </View>
    );
  }

  return (
    <View style={S.container}>
      {/* Header */}
      <View style={S.header}>
        <View style={S.headerContent}>
          <Text style={S.headerTitle}>Messages</Text>
          {totalUnread > 0 && (
            <Text style={S.headerSubtitle}>{totalUnread} non lu{totalUnread > 1 ? 's' : ''}</Text>
          )}
        </View>
        <TouchableOpacity onPress={openNewConversationModal} style={S.headerBtn}>
          <MaterialIcons name="edit" size={22} color="#FFF" />
        </TouchableOpacity>
      </View>

      {/* Search */}
      <View style={S.searchContainer}>
        <MaterialIcons name="search" size={20} color={Neutral[400]} style={{ marginRight: 8 }} />
        <TextInput
          placeholder="Rechercher..."
          placeholderTextColor={Neutral[400]}
          value={searchQuery}
          onChangeText={handleSearchChange}
          style={S.searchInput}
        />
        {searchQuery.length > 0 && (
          <TouchableOpacity onPress={() => handleSearchChange('')}>
            <MaterialIcons name="close" size={18} color={Neutral[400]} />
          </TouchableOpacity>
        )}
      </View>

      {/* List */}
      <FlatList
        data={filtered}
        renderItem={renderItem}
        keyExtractor={item => item.kind === 'dm' ? `dm-${item.conv.otherUserId}` : `group-${item.group.id}`}
        contentContainerStyle={S.list}
        refreshControl={<RefreshControl refreshing={refreshing} onRefresh={handleRefresh} />}
        ListEmptyComponent={
          <View style={S.emptyContainer}>
            <MaterialIcons name="chat-bubble-outline" size={48} color={Neutral[300]} />
            <Text style={S.emptyText}>Aucune conversation</Text>
            <Text style={S.emptySubtext}>
              {searchQuery ? 'Aucun résultat trouvé' : 'Commencez à discuter avec vos contacts GoodFriends'}
            </Text>
          </View>
        }
      />

      {/* New conversation modal */}
      <Modal visible={modalVisible} animationType="slide" transparent onRequestClose={() => setModalVisible(false)}>
        <View style={S.modalOverlay}>
          <View style={S.modalContainer}>
            {/* Modal header */}
            <View style={S.modalHeader}>
              {groupStep === 'name' ? (
                <TouchableOpacity onPress={() => setGroupStep('select')} style={S.modalBackBtn}>
                  <MaterialIcons name="arrow-back" size={22} color={theme.primary} />
                </TouchableOpacity>
              ) : (
                <TouchableOpacity onPress={() => setModalVisible(false)} style={S.modalBackBtn}>
                  <MaterialIcons name="close" size={22} color={Neutral[500]} />
                </TouchableOpacity>
              )}
              <Text style={S.modalTitle}>
                {groupStep === 'name' ? 'Nom du groupe' : 'Nouvelle conversation'}
              </Text>
              <View style={{ width: 32 }} />
            </View>

            {groupStep === 'select' ? (
              <>
                {/* Selection hint */}
                <Text style={S.selectionHint}>
                  {selectedIds.length === 0
                    ? 'Sélectionnez un ou plusieurs contacts'
                    : selectedIds.length === 1
                      ? '1 sélectionné — conversation individuelle'
                      : `${selectedIds.length} sélectionnés — groupe`}
                </Text>

                {/* Contact list */}
                {loadingContacts ? (
                  <ActivityIndicator style={{ marginTop: 40 }} color={theme.primary} />
                ) : (
                  <ScrollView style={S.contactsList} keyboardShouldPersistTaps="handled">
                    {goodFriendsContacts.length === 0 ? (
                      <Text style={S.noContactsText}>Aucun contact GoodFriends trouvé</Text>
                    ) : (
                      goodFriendsContacts.map(contact => {
                        const selected = selectedIds.includes(contact.id);
                        const name = formatName(contact.firstName, contact.lastName, contact.email);
                        const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
                        return (
                          <TouchableOpacity
                            key={contact.id}
                            style={[S.contactItem, selected && S.contactItemSelected]}
                            onPress={() => toggleContact(contact.id)}
                            activeOpacity={0.7}>
                            <View style={[S.contactAvatar, selected && { backgroundColor: theme.primary }]}>
                              {selected
                                ? <MaterialIcons name="check" size={18} color="#FFF" />
                                : <Text style={S.contactAvatarText}>{initials}</Text>}
                            </View>
                            <Text style={S.contactName}>{name}</Text>
                          </TouchableOpacity>
                        );
                      })
                    )}
                  </ScrollView>
                )}

                {/* Confirm button */}
                <TouchableOpacity
                  style={[S.confirmBtn, selectedIds.length === 0 && S.confirmBtnDisabled]}
                  onPress={handleConfirmSelection}
                  disabled={selectedIds.length === 0}
                  activeOpacity={0.8}>
                  <Text style={S.confirmBtnText}>
                    {selectedIds.length <= 1 ? 'Ouvrir la conversation' : 'Créer un groupe'}
                  </Text>
                  <MaterialIcons name="arrow-forward" size={20} color="#FFF" />
                </TouchableOpacity>
              </>
            ) : (
              /* Group name step */
              <View style={S.groupNameStep}>
                <Text style={S.groupNameLabel}>Nom du groupe</Text>
                <TextInput
                  style={S.groupNameInput}
                  placeholder="Ex: Les copains de bureau"
                  placeholderTextColor={Neutral[400]}
                  value={groupName}
                  onChangeText={setGroupName}
                  autoFocus
                  maxLength={60}
                />
                <Text style={S.groupMembersHint}>
                  {selectedIds.length} participant{selectedIds.length > 1 ? 's' : ''}
                </Text>
                <TouchableOpacity
                  style={[S.confirmBtn, (!groupName.trim() || creatingGroup) && S.confirmBtnDisabled]}
                  onPress={handleCreateGroup}
                  disabled={!groupName.trim() || creatingGroup}
                  activeOpacity={0.8}>
                  {creatingGroup
                    ? <ActivityIndicator color="#FFF" size="small" />
                    : <>
                        <Text style={S.confirmBtnText}>Créer le groupe</Text>
                        <MaterialIcons name="group-add" size={20} color="#FFF" />
                      </>}
                </TouchableOpacity>
              </View>
            )}
          </View>
        </View>
      </Modal>
    </View>
  );
};

const styles = (theme: any) => StyleSheet.create({
  container: {
    flex: 1,
    backgroundColor: theme.background,
  },
  header: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingHorizontal: Spacing[4],
    paddingTop: Platform.OS === 'ios' ? 54 : 16,
    paddingBottom: 12,
    backgroundColor: theme.primary,
    ...Shadow.md,
  },
  headerContent: { flex: 1 },
  headerTitle: {
    fontSize: Typography.size.xl,
    fontWeight: '700',
    color: '#FFF',
  },
  headerSubtitle: {
    fontSize: Typography.size.xs,
    color: 'rgba(255,255,255,0.8)',
    marginTop: 2,
  },
  headerBtn: {
    width: 38,
    height: 38,
    borderRadius: 19,
    backgroundColor: 'rgba(255,255,255,0.2)',
    alignItems: 'center',
    justifyContent: 'center',
  },
  searchContainer: {
    flexDirection: 'row',
    alignItems: 'center',
    backgroundColor: theme.surface || '#fff',
    borderRadius: Radius.md,
    marginHorizontal: Spacing[4],
    marginVertical: Spacing[3],
    paddingHorizontal: Spacing[3],
    paddingVertical: Platform.OS === 'ios' ? 10 : 6,
    ...Shadow.sm,
  },
  searchInput: {
    flex: 1,
    fontSize: Typography.size.sm,
    color: theme.text,
    padding: 0,
  },
  list: {
    paddingBottom: 16,
  },
  item: {
    flexDirection: 'row',
    alignItems: 'center',
    paddingHorizontal: Spacing[4],
    paddingVertical: Spacing[3],
    backgroundColor: theme.surface || '#fff',
    borderBottomWidth: StyleSheet.hairlineWidth,
    borderBottomColor: Neutral[200],
  },
  itemUnread: {
    backgroundColor: theme.primary + '10',
  },
  avatarCircle: {
    width: 48,
    height: 48,
    borderRadius: 24,
    backgroundColor: theme.primary,
    alignItems: 'center',
    justifyContent: 'center',
    marginRight: Spacing[3],
  },
  avatarText: {
    color: '#FFF',
    fontWeight: '700',
    fontSize: 17,
  },
  itemInfo: { flex: 1, minWidth: 0 },
  itemTop: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'center',
    marginBottom: 2,
  },
  itemName: {
    flex: 1,
    fontSize: Typography.size.md,
    fontWeight: '500',
    color: theme.text,
    marginRight: 8,
  },
  itemNameBold: { fontWeight: '700' },
  timeText: {
    fontSize: Typography.size.xs,
    color: Neutral[500],
  },
  itemBottom: {
    flexDirection: 'row',
    alignItems: 'center',
  },
  lastMessage: {
    flex: 1,
    fontSize: Typography.size.sm,
    color: Neutral[500],
  },
  lastMessageBold: {
    color: theme.text,
    fontWeight: '600',
  },
  badge: {
    minWidth: 20,
    height: 20,
    borderRadius: 10,
    backgroundColor: theme.primary,
    alignItems: 'center',
    justifyContent: 'center',
    paddingHorizontal: 4,
    marginLeft: 6,
  },
  badgeText: {
    color: '#FFF',
    fontSize: 11,
    fontWeight: '700',
  },
  loadingContainer: {
    flex: 1,
    alignItems: 'center',
    justifyContent: 'center',
  },
  emptyContainer: {
    flex: 1,
    alignItems: 'center',
    justifyContent: 'center',
    paddingTop: 80,
    paddingHorizontal: Spacing[6],
  },
  emptyText: {
    fontSize: Typography.size.lg,
    fontWeight: '600',
    color: theme.text,
    marginTop: Spacing[3],
    marginBottom: Spacing[2],
  },
  emptySubtext: {
    fontSize: Typography.size.sm,
    color: Neutral[500],
    textAlign: 'center',
  },
  // Modal
  modalOverlay: {
    flex: 1,
    backgroundColor: 'rgba(0,0,0,0.5)',
    justifyContent: 'flex-end',
  },
  modalContainer: {
    backgroundColor: theme.background || '#fff',
    borderTopLeftRadius: Radius.xl,
    borderTopRightRadius: Radius.xl,
    maxHeight: '85%',
    paddingBottom: Platform.OS === 'ios' ? 34 : 16,
  },
  modalHeader: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingHorizontal: Spacing[4],
    paddingVertical: Spacing[3],
    borderBottomWidth: StyleSheet.hairlineWidth,
    borderBottomColor: Neutral[200],
  },
  modalBackBtn: { padding: 4 },
  modalTitle: {
    fontSize: Typography.size.lg,
    fontWeight: '700',
    color: theme.text,
  },
  selectionHint: {
    fontSize: Typography.size.sm,
    color: Neutral[500],
    paddingHorizontal: Spacing[4],
    paddingTop: Spacing[3],
    paddingBottom: Spacing[2],
  },
  contactsList: {
    maxHeight: 380,
    paddingHorizontal: Spacing[2],
  },
  noContactsText: {
    textAlign: 'center',
    color: Neutral[400],
    paddingVertical: Spacing[8],
    fontSize: Typography.size.sm,
  },
  contactItem: {
    flexDirection: 'row',
    alignItems: 'center',
    paddingHorizontal: Spacing[3],
    paddingVertical: Spacing[3],
    borderRadius: Radius.md,
    marginVertical: 1,
  },
  contactItemSelected: {
    backgroundColor: theme.primary + '18',
  },
  contactAvatar: {
    width: 40,
    height: 40,
    borderRadius: 20,
    backgroundColor: Neutral[200],
    alignItems: 'center',
    justifyContent: 'center',
    marginRight: Spacing[3],
  },
  contactAvatarText: {
    fontWeight: '700',
    color: Neutral[600],
    fontSize: 15,
  },
  contactName: {
    fontSize: Typography.size.md,
    color: theme.text,
    flex: 1,
  },
  confirmBtn: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'center',
    gap: 8,
    backgroundColor: theme.primary,
    borderRadius: Radius.md,
    marginHorizontal: Spacing[4],
    marginTop: Spacing[4],
    paddingVertical: 14,
  },
  confirmBtnDisabled: {
    backgroundColor: Neutral[300],
  },
  confirmBtnText: {
    color: '#FFF',
    fontWeight: '700',
    fontSize: Typography.size.md,
  },
  groupNameStep: {
    paddingHorizontal: Spacing[4],
    paddingTop: Spacing[4],
  },
  groupNameLabel: {
    fontSize: Typography.size.sm,
    fontWeight: '600',
    color: Neutral[600],
    marginBottom: Spacing[2],
  },
  groupNameInput: {
    borderWidth: 1.5,
    borderColor: Neutral[300],
    borderRadius: Radius.md,
    paddingHorizontal: Spacing[3],
    paddingVertical: Platform.OS === 'ios' ? 12 : 8,
    fontSize: Typography.size.md,
    color: theme.text,
    marginBottom: Spacing[3],
  },
  groupMembersHint: {
    fontSize: Typography.size.sm,
    color: Neutral[500],
    marginBottom: Spacing[4],
  },
});

export default ConversationsScreen;
